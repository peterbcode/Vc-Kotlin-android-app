<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingStart="16dp"
    android:paddingTop="4dp"
    android:paddingEnd="16dp"
    android:paddingBottom="120dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_panel"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_chip"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="Riebeek Valley local service"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWelcome"
                style="@style/TextAppearance.VCClientAndroidApp.HeroTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="From fibre sign-ups to home networking and expert repairs, everything is arranged around quick access and local support."
                android:textColor="@color/hero_text_muted"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGetConnected"
                style="@style/Widget.VCClientAndroidApp.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/brand_teal"
                android:text="Get connected"
                android:textColor="@color/black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckCoverage"
                style="@style/Widget.VCClientAndroidApp.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Check coverage"
                android:textColor="@color/brand_sand"
                app:strokeColor="@color/brand_teal" />
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.VCClientAndroidApp.Overline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Services" />

        <TextView
            style="@style/TextAppearance.VCClientAndroidApp.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Everything your website highlights, organised for mobile." />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIsp"
            style="@style/Widget.VCClientAndroidApp.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            app:rippleColor="@color/surface_muted">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.VCClientAndroidApp.Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ISP Services" />

                <TextView
                    style="@style/TextAppearance.VCClientAndroidApp.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Fibre and wireless access with quick paths to connection requests and coverage checks." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRepairs"
            style="@style/Widget.VCClientAndroidApp.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            app:rippleColor="@color/surface_muted">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.VCClientAndroidApp.Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Repairs and Support" />

                <TextView
                    style="@style/TextAppearance.VCClientAndroidApp.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Book help fast for machines that need attention, upgrades, or troubleshooting." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNetwork"
            style="@style/Widget.VCClientAndroidApp.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            app:rippleColor="@color/surface_muted">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.VCClientAndroidApp.Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Network Solutions" />

                <TextView
                    style="@style/TextAppearance.VCClientAndroidApp.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Structured networking and on-site support presented as a clean mobile service hub." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAccount"
            style="@style/Widget.VCClientAndroidApp.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            app:rippleColor="@color/surface_muted">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TextAppearance.VCClientAndroidApp.Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Account Dashboard" />

                <TextView
                    style="@style/TextAppearance.VCClientAndroidApp.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Save your details, view recent requests and speed up future bookings." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
