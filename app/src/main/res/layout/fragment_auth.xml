<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@mipmap/ic_launcher_foreground"
        app:tint="@color/brand_teal" />

    <TextView
        style="@style/TextAppearance.VCClientAndroidApp.HeroTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Welcome to Valley"
        android:textAlignment="center" />

    <TextView
        style="@style/TextAppearance.VCClientAndroidApp.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Sign in to manage your services and application forms."
        android:textAlignment="center"
        android:textColor="@color/text_secondary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogleSignIn"
        style="@style/Widget.VCClientAndroidApp.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:padding="12dp"
        android:text="Sign in with Google"
        app:icon="@drawable/ic_google"
        app:iconGravity="textStart"
        app:strokeColor="@color/surface_border" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEmailSignIn"
        style="@style/Widget.VCClientAndroidApp.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Continue with Email" />

    <TextView
        android:id="@+id/tvSkipAuth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:padding="12dp"
        android:text="Browse as Guest"
        android:textColor="@color/brand_teal"
        android:textStyle="bold" />

</LinearLayout>
