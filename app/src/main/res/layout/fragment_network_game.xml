<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btnBackFromGame"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@drawable/ic_home"
        android:tint="#FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvGameStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="CRITICAL ERROR:\nNetwork Nodes Offline"
            android:textColor="#FF5252"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Toggle nodes to sync the mesh network"
            android:textColor="#888888"
            android:textSize="14sp" />

        <GridLayout
            android:id="@+id/glGameGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:columnCount="3"
            android:rowCount="3"
            android:useDefaultMargins="true">
            <!-- Programmatically populated -->
        </GridLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetGame"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="REBOOT SYSTEM"
            android:textColor="#4CAF50"
            android:visibility="gone" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:alpha="0.5"
        android:text="Easter Egg: Network Repair v1.0"
        android:textColor="#FFFFFF"
        android:textSize="10sp" />

</RelativeLayout>
