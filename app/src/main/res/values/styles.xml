<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.VCClientAndroidApp.Overline" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textColor">@color/brand_teal</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.VCClientAndroidApp.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.VCClientAndroidApp.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="TextAppearance.VCClientAndroidApp.HeroTitle" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/hero_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.VCClientAndroidApp.HeroBody" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/hero_text_muted</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="Widget.VCClientAndroidApp.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="strokeColor">@color/surface_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <style name="Widget.VCClientAndroidApp.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_teal</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="Widget.VCClientAndroidApp.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_teal</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textColor">@color/brand_teal</item>
    </style>

    <!-- Style for EditText to fix dark text visibility -->
    <style name="Widget.VCClientAndroidApp.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <!-- Style for CheckBox to fix dark text visibility -->
    <style name="Widget.VCClientAndroidApp.CheckBox" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="buttonTint">@color/brand_teal</item>
    </style>

    <!-- Style for RadioButton to fix dark text visibility -->
    <style name="Widget.VCClientAndroidApp.RadioButton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="buttonTint">@color/brand_teal</item>
    </style>
</resources>
